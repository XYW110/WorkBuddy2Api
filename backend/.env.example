# ========================================
# WorkBuddy2Api 后端环境变量模板
# 复制此文件为 .env 后修改
# ========================================

# 管理 Token（必填，未配置时 /admin/* 返回 503）
ADMIN_TOKEN=change-me-in-production

# 监听配置（可被 config.json 覆盖）
PORT=3000
HOST=127.0.0.1

# 数据存储目录（默认 ./data）
DATA_DIR=./data

# CORS 白名单（逗号分隔，未配置不下发跨域头）
CORS_ORIGIN=

# 运行环境（production 时禁用 pino-pretty 彩色输出）
NODE_ENV=development