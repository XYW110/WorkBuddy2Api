# ==========================================
# Docker Compose 环境变量（复制为 .env 后修改）
# ==========================================

# 管理 Token（必填，否则 /admin/* 拒绝服务）
ADMIN_TOKEN=change-me-in-production

# 宿主机映射端口（容器内固定 11434）
PORT=11434

# 宿主机数据目录（持久化凭证/签到历史等 JSON 文件）
DATA_DIR=/opt/workbuddy2api

# CORS 白名单，逗号分隔（同源托管可留空）
CORS_ORIGIN=

# 可选：/v1 客户端 API Key（未配置则不校验）
# API_KEY=sk-your-key-here
