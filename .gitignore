.trellis/skills/
.trellis/.template-hashes.json
# 保留: spec/ workflow.md scripts/ tasks/ config.yaml

# ========================================
# AI 助手工具（保留配置，忽略运行时）
# ========================================
# CodeBuddy
.codebuddy/.cache/
.codebuddy/.log/

# Snow CLI
.snow/log/
.snow/locks/
.snow/notebook/
